#!/usr/bin/env bash
# DevForge SessionStart hook
# Auto-detects current project and injects context + recording rules

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
DB_PATH="${HOME}/.devforge/devforge.db"

# Check if DB exists
if [ ! -f "$DB_PATH" ]; then
  exit 0
fi

# Detect current project from git
project_slug=""
project_info=""
if command -v git &>/dev/null && git rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
  dir_name=$(basename "$(pwd)")
  # Try to match by slug
  project_slug=$(sqlite3 "$DB_PATH" "SELECT slug FROM projects WHERE slug = '$(echo "$dir_name" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g')' LIMIT 1" 2>/dev/null || echo "")

  if [ -n "$project_slug" ]; then
    # Get project details
    p_name=$(sqlite3 "$DB_PATH" "SELECT name FROM projects WHERE slug = '$project_slug'" 2>/dev/null || echo "")
    p_stage=$(sqlite3 "$DB_PATH" "SELECT stage FROM projects WHERE slug = '$project_slug'" 2>/dev/null || echo "")
    p_progress=$(sqlite3 "$DB_PATH" "SELECT progress_pct FROM projects WHERE slug = '$project_slug'" 2>/dev/null || echo "0")
    p_phase=$(sqlite3 "$DB_PATH" "SELECT progress_phase FROM projects WHERE slug = '$project_slug'" 2>/dev/null || echo "")
    p_id=$(sqlite3 "$DB_PATH" "SELECT id FROM projects WHERE slug = '$project_slug'" 2>/dev/null || echo "")

    # Get open issues
    open_count=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM issues WHERE project_id = $p_id AND status IN ('open', 'in-progress')" 2>/dev/null || echo "0")

    # Get top 3 open issues
    top_issues=$(sqlite3 "$DB_PATH" "SELECT '[' || priority || '] #' || id || ' ' || title FROM issues WHERE project_id = $p_id AND status = 'open' ORDER BY CASE priority WHEN 'high' THEN 0 WHEN 'medium' THEN 1 ELSE 2 END LIMIT 3" 2>/dev/null || echo "")

    # Get recent feedback count
    feedback_count=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM feedback WHERE project_id = $p_id AND status = 'open'" 2>/dev/null || echo "0")

    project_info="Current DevForge Project: ${p_name} (${p_stage}, ${p_progress}% — ${p_phase})"
    if [ "$open_count" -gt 0 ]; then
      project_info="${project_info}\\nOpen Issues: ${open_count}"
      if [ -n "$top_issues" ]; then
        project_info="${project_info}\\n$(echo "$top_issues" | sed 's/$/\\n/' | tr -d '\n')"
      fi
    fi
    if [ "$feedback_count" -gt 0 ]; then
      project_info="${project_info}\\nNew Feedback: ${feedback_count}"
    fi
  fi
fi

# Build context injection
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

context_parts="DevForge is connected via MCP. You have 8 tools: devforge_list_projects, devforge_get_project, devforge_add_issue, devforge_update_issue, devforge_add_note, devforge_update_progress, devforge_get_feedback, devforge_scan."

if [ -n "$project_info" ]; then
  context_parts="${context_parts}\\n\\n${project_info}"
fi

context_parts="${context_parts}\\n\\n**AUTO-RECORD RULES (MANDATORY):**\\n- When you discover a bug or problem → immediately call devforge_add_issue (type=bug)\\n- When user reports a problem → immediately call devforge_add_issue\\n- When you fix a known issue → call devforge_update_issue to mark resolved\\n- When you make a design decision → call devforge_add_note\\n- When you encounter unexpected behavior → call devforge_add_issue (type=bug)\\n- When finishing a task → update progress via devforge_update_progress\\n- Do NOT wait to be asked. Record proactively. Every bug found = 1 issue created."

session_context=$(escape_for_json "$context_parts")

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF
else
  cat <<EOF
{
  "additional_context": "${session_context}"
}
EOF
fi

exit 0
